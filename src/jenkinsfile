pipeline{
    agent any
    stages {
        stage('Clone Code') {
            steps{
                git branch: 'main',url:'https://github.com/Ayush-pd07/login-poc.git'
            }
        }
        stage('Build Docker Image'){
            steps{
                sh 'docker build -t mysite .'
            }
        }
        stage('Stop Old Container'){
            steps{
                sh 'docker stop mysite || true'
                sh 'docker rm mysite || true'
            }
        }
        stage('Run New Container'){
            steps {
                sh 'docker run -d -p 3000:80 --name mysite mysite'
            }
        }
    }
}